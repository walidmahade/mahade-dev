---
import '@/styles/global.css';
import Header from '@/components/site/Header.astro';
import Footer from '@/components/site/Footer.astro';
import { site } from '@/data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Hide the sticky header (e.g. 404 page). */
  hideHeader?: boolean;
  /** Hide the footer. */
  hideFooter?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og-default.svg',
  noindex = false,
  hideHeader = false,
  hideFooter = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: site.title,
  image: `${site.url}/images/mahade-headshot.webp`,
  email: `mailto:${site.email}`,
  sameAs: [site.links.github, site.links.upwork].filter(Boolean),
  knowsAbout: [
    'Webflow',
    'Web development',
    'SEO',
    'Performance optimization',
    'Frontend development',
  ],
};

const isProd = import.meta.env.PROD;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    {isProd && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.gaId}`}></script>
        <script is:inline define:vars={{ gaId: site.gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </>
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    {!hideHeader && <Header />}
    <main class="flex-1"><slot /></main>
    {!hideFooter && <Footer />}
  </body>
</html>
