---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import Eyebrow from '@/components/layout/Eyebrow.astro';
import DisplayHeading from '@/components/layout/DisplayHeading.astro';
import { projects, type Project } from '@/data/projects';
import { site } from '@/data/site';
import { jsonLd } from '@/lib/jsonld';
import { ArrowUpRight } from 'lucide-react';
import CtaBanner from '@/components/layout/CtaBanner.astro';

export function getStaticPaths() {
  return projects
    .filter((p) => p.featured)
    .map((p) => ({
      params: { slug: p.slug },
      props: { project: p },
    }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const caseSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.name,
  creator: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  about: project.industry,
  url: `${site.url}/work/${project.slug}/`,
  image: `${site.url}${project.heroImage}`,
  datePublished: `${project.year}-01-01`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Work', item: `${site.url}/work/` },
    {
      '@type': 'ListItem',
      position: 3,
      name: project.name,
      item: `${site.url}/work/${project.slug}/`,
    },
  ],
};
---
<Layout
  title={`${project.name} — Webflow Case Study | Mahade Walid`}
  description={project.description}
  ogImage={project.heroImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(caseSchema)} />
    <script type="application/ld+json" set:html={jsonLd(breadcrumbSchema)} />
  </Fragment>

  <article>
    <Section size="page-head" tone="paper">
      <Container>
        <nav class="text-body-sm text-ink-subtle" aria-label="Breadcrumb">
          <a href="/" class="hover:text-ink transition-colors">Home</a>
          <span aria-hidden="true"> / </span>
          <a href="/work/" class="hover:text-ink transition-colors">Work</a>
          <span aria-hidden="true"> / </span>
          <span class="text-ink-muted">{project.name}</span>
        </nav>

        <div class="mt-5 max-w-3xl">
          <Eyebrow>{project.industry} · {project.year}</Eyebrow>
          <DisplayHeading as="h1" size="sm" class="mt-2">
            {project.name}
          </DisplayHeading>
          <p class="mt-3 text-ink-muted">
            {project.description}
          </p>
        </div>

        <div class="mt-5 flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="rounded-full bg-brand-soft px-3 py-1 text-xs font-medium text-brand">
              {tag}
            </span>
          ))}
        </div>

        <a
          href={project.liveUrl}
          target="_blank"
          rel="noopener"
          class="mt-5 inline-flex h-11 items-center gap-2 rounded-[10px] bg-ink px-5 font-medium text-paper hover:-translate-y-0.5 transition-transform"
        >
          Visit live site <ArrowUpRight size={18} strokeWidth={2} />
        </a>
      </Container>
    </Section>

    <Section tone="tint" size="compact">
      <Container>
        <div class="rounded-xl overflow-hidden border border-line bg-paper-sunken">
          <img
            src={project.heroImage}
            alt={`${project.name} hero screenshot`}
            class="w-full"
          />
        </div>
      </Container>
    </Section>

    {project.results && project.results.length > 0 && (
      <Section tone="paper">
        <Container>
          <Eyebrow>Results</Eyebrow>
          <dl class="mt-6 grid gap-8 md:grid-cols-3">
            {project.results.map((r) => (
              <div>
                <dt class="text-body-sm text-ink-muted">{r.label}</dt>
                <dd class="mt-1 text-display-md text-ink">{r.value}</dd>
              </div>
            ))}
          </dl>
        </Container>
      </Section>
    )}

    {project.problem && (
      <Section tone="paper" size="compact">
        <Container width="prose">
          <Eyebrow>Problem</Eyebrow>
          <p class="mt-4 text-body-lg text-ink">{project.problem}</p>
        </Container>
      </Section>
    )}

    {project.approach && (
      <Section tone="paper" size="compact">
        <Container width="prose">
          <Eyebrow>Approach</Eyebrow>
          <p class="mt-4 text-body-lg text-ink">{project.approach}</p>
        </Container>
      </Section>
    )}

    {project.screenshots && project.screenshots.length > 0 && (
      <Section tone="tint">
        <Container>
          <Eyebrow>More screens</Eyebrow>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            {project.screenshots.map((s, i) => (
              <img
                src={s}
                alt={`${project.name} screenshot ${i + 1}`}
                class="rounded-xl border border-line w-full"
                loading="lazy"
              />
            ))}
          </div>
        </Container>
      </Section>
    )}

    <CtaBanner
      heading="Want something similar?"
      primary={{ label: 'Book a call', href: site.links.cal, external: true }}
      secondary={{ label: 'See more work', href: '/work/' }}
    />
  </article>
</Layout>
