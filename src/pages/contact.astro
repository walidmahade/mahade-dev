---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/layout/Section.astro';
import Container from '@/components/layout/Container.astro';
import Eyebrow from '@/components/layout/Eyebrow.astro';
import DisplayHeading from '@/components/layout/DisplayHeading.astro';
import CalEmbed from '@/components/contact/CalEmbed.astro';
import { site } from '@/data/site';
import { ArrowUpRight, Mail } from 'lucide-react';
---
<Layout
  title="Contact — Mahade Walid, Webflow Developer"
  description="Book a 30-minute call, hire via Upwork, or email directly. I reply within 24 hours on weekdays."
>
  <Section size="page-head" tone="paper">
    <Container>
      <Eyebrow>Contact</Eyebrow>
      <DisplayHeading as="h1" size="sm" class="mt-2 max-w-3xl">
        Let&rsquo;s talk about your project.
      </DisplayHeading>
      <p class="mt-3 max-w-2xl text-ink-muted">
        The fastest path is a 30-minute call. Email works too.
      </p>
    </Container>
  </Section>

  <Section tone="tint">
    <Container>
      <div class="grid gap-8 lg:grid-cols-[2fr_1fr]">
        <div class="rounded-xl border border-line bg-paper p-2 md:p-4 overflow-hidden">
          <CalEmbed />
        </div>

        <aside class="space-y-4">
          <a
            href={site.links.upwork}
            target="_blank"
            rel="noopener"
            class="group block rounded-xl border border-line bg-paper p-6 hover:border-line-strong transition-colors"
          >
            <Eyebrow>Upwork</Eyebrow>
            <p class="mt-2 text-heading-md text-ink">Hire through Upwork</p>
            <p class="mt-2 text-body-sm text-ink-muted">
              Fixed-scope or hourly engagements with escrow protection.
            </p>
            <span class="mt-4 inline-flex items-center gap-2 text-brand font-medium group-hover:gap-3 transition-all">
              Go to profile <ArrowUpRight size={18} strokeWidth={2} />
            </span>
          </a>

          <a
            href={`mailto:${site.email}?subject=Webflow%20project%20inquiry`}
            class="group block rounded-xl border border-line bg-paper p-6 hover:border-line-strong transition-colors"
          >
            <Eyebrow>Email</Eyebrow>
            <p class="mt-2 text-heading-md text-ink break-all">{site.email}</p>
            <p class="mt-2 text-body-sm text-ink-muted">
              Direct email. Reply within 24 hours on weekdays.
            </p>
            <span class="mt-4 inline-flex items-center gap-2 text-brand font-medium group-hover:gap-3 transition-all">
              Send email <Mail size={18} strokeWidth={2} />
            </span>
          </a>

          <div class="rounded-xl bg-paper-sunken p-6">
            <Eyebrow>Response time</Eyebrow>
            <p class="mt-3 text-body-sm text-ink leading-relaxed">
              Weekdays: within 24 hours.<br />
              Weekends: Monday morning.<br />
              Timezone: Bangladesh (UTC+6).
            </p>
          </div>
        </aside>
      </div>
    </Container>
  </Section>
</Layout>
