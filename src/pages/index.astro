---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/home/Hero.astro';
import TrustBar from '@/components/home/TrustBar.astro';
import Services from '@/components/home/Services.astro';
import FeaturedWork from '@/components/home/FeaturedWork.astro';
import Process from '@/components/home/Process.astro';
import Pricing from '@/components/home/Pricing.astro';
import Testimonial from '@/components/home/Testimonial.astro';
import Faq from '@/components/home/Faq.astro';
import FinalCta from '@/components/home/FinalCta.astro';
import HomeMotion from '@/components/home/HomeMotion';
import { site } from '@/data/site';
import { faq } from '@/data/faq';
import { jsonLd } from '@/lib/jsonld';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Webflow Developer for Hire',
  provider: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  serviceType: 'Webflow Development',
  areaServed: { '@type': 'Place', name: 'Worldwide' },
  description:
    'Hire an expert Webflow developer for agencies and in-house teams. Unlimited pages on a flat monthly retainer, or hourly engagements via Upwork.',
  offers: [
    {
      '@type': 'Offer',
      name: 'Monthly retainer — unlimited Webflow pages',
      price: '1999',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'Hourly via Upwork',
      price: '50',
      priceCurrency: 'USD',
      url: site.links.upwork,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---
<Layout
  title="Hire a Webflow Developer — Mahade Walid"
  description="Hire an expert Webflow developer for agencies & SaaS teams. Unlimited pages on a flat monthly retainer, or hourly via Upwork. Fast, SEO-ready builds."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(serviceSchema)} />
    <script type="application/ld+json" set:html={jsonLd(faqSchema)} />
  </Fragment>

  <Hero />
  <TrustBar />
  <Services />
  <FeaturedWork />
  <Process />
  <Pricing />
  <Testimonial />
  <Faq />
  <FinalCta />
  <HomeMotion client:load />
</Layout>
