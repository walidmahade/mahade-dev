---
import { site } from '@/data/site';
---
<div class="rounded-xl border border-line bg-paper-tint p-6 md:p-8">
  <p class="text-eyebrow text-brand">Prefer someone else does this?</p>
  <h3 class="mt-2 text-heading-lg text-ink">
    Hire a Webflow developer for a flat monthly rate.
  </h3>
  <p class="mt-2 text-ink-muted">
    Unlimited pages. One request at a time. 48-hour turnaround. Pause or cancel any time.
  </p>
  <div class="mt-5 flex flex-wrap gap-3">
    <a
      href={site.links.cal}
      target="_blank"
      rel="noopener"
      class="inline-flex h-11 items-center rounded-[10px] bg-brand px-5 font-medium text-white hover:bg-brand-hover hover:-translate-y-0.5 transition-all"
    >
      Book a 30-min call
    </a>
    <a
      href="/"
      class="inline-flex h-11 items-center rounded-[10px] border border-line-strong px-5 font-medium text-ink hover:bg-paper transition-colors"
    >
      See how it works
    </a>
  </div>
</div>
