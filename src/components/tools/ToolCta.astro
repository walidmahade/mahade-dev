---
import { site } from '@/data/site';
---
<div class="not-prose mt-10 rounded-xl bg-ink text-paper p-8 md:p-10 relative overflow-hidden">
  <div
    aria-hidden="true"
    class="absolute -top-20 -right-20 h-56 w-56 rounded-full bg-brand/25 blur-3xl"
  ></div>
  <div class="relative">
    <p class="text-eyebrow text-brand-soft">Prefer someone else does this?</p>
    <h3 class="mt-2 text-heading-lg text-paper">
      Hire a Webflow developer for a flat monthly rate.
    </h3>
    <p class="mt-2 text-paper/75">
      Unlimited pages. One request at a time. 48-hour turnaround. Pause or cancel any time.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href={site.links.cal}
        target="_blank"
        rel="noopener"
        class="inline-flex h-11 items-center rounded-[10px] bg-brand px-5 font-medium !text-white no-underline hover:bg-brand-hover hover:-translate-y-0.5 transition-all"
      >
        Book a 30-min call
      </a>
      <a
        href="/"
        class="inline-flex h-11 items-center rounded-[10px] border border-paper/30 px-5 font-medium !text-paper no-underline hover:bg-paper/10 transition-colors"
      >
        See how it works
      </a>
    </div>
  </div>
</div>
