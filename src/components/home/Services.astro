---
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Eyebrow from '../layout/Eyebrow.astro';
import DisplayHeading from '../layout/DisplayHeading.astro';
import { services } from '@/data/services';
import { Layers, Search, Zap, Wrench } from 'lucide-react';

const iconMap = {
  layers: Layers,
  search: Search,
  zap: Zap,
  wrench: Wrench,
};
---
<Section tone="paper" id="services">
  <Container>
    <div class="max-w-2xl mb-12" data-reveal>
      <Eyebrow>Services</Eyebrow>
      <DisplayHeading as="h2" size="lg" class="mt-3">
        Everything you need, under one retainer
      </DisplayHeading>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => {
        const Icon = iconMap[service.icon];
        return (
          <div
            data-reveal
            class="rounded-lg border border-line bg-paper p-6 md:p-8 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
          >
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-brand-soft text-brand">
              <Icon size={22} strokeWidth={1.75} />
            </div>
            <h3 class="mt-5 text-heading-md text-ink">{service.title}</h3>
            <p class="mt-2 text-ink-muted">{service.body}</p>
          </div>
        );
      })}
    </div>
  </Container>
</Section>
