---
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Eyebrow from '../layout/Eyebrow.astro';
import DisplayHeading from '../layout/DisplayHeading.astro';
import { pricing } from '@/data/pricing';
import { Check } from 'lucide-react';
---
<Section tone="tint" id="pricing">
  <Container>
    <div class="max-w-2xl mb-12 mx-auto text-center" data-reveal>
      <Eyebrow>Pricing</Eyebrow>
      <DisplayHeading as="h2" size="lg" class="mt-3">
        Transparent, no surprises
      </DisplayHeading>
      <p class="mt-4 text-body-lg text-ink-muted">
        Pick the engagement that fits. Monthly retainer for ongoing volume, hourly through Upwork for scoped work.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 max-w-5xl mx-auto">
      {pricing.map((tier) => (
        <div
          data-reveal
          class:list={[
            'rounded-xl p-8 md:p-10 flex flex-col',
            tier.featured
              ? 'bg-ink text-paper ring-1 ring-ink relative'
              : 'bg-paper border border-line',
          ]}
        >
          {tier.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand px-3 py-1 text-xs font-semibold text-white">
              Most popular
            </span>
          )}
          <p class:list={['text-eyebrow', tier.featured ? 'text-brand-soft' : 'text-ink-muted']}>
            {tier.name}
          </p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-display-md font-display">{tier.price}</span>
            <span class={tier.featured ? 'text-paper/70' : 'text-ink-muted'}>
              {tier.cadence}
            </span>
          </div>
          <p class:list={['mt-4', tier.featured ? 'text-paper/80' : 'text-ink-muted']}>
            {tier.description}
          </p>
          <ul class="mt-6 space-y-3 flex-1">
            {tier.features.map((feature) => (
              <li class="flex gap-3">
                <Check
                  size={18}
                  strokeWidth={2.5}
                  className={tier.featured ? 'text-brand-soft flex-shrink-0 mt-0.5' : 'text-brand flex-shrink-0 mt-0.5'}
                />
                <span class={tier.featured ? 'text-paper/90' : 'text-ink'}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>
          <a
            href={tier.cta.href}
            target="_blank"
            rel="noopener"
            class:list={[
              'mt-8 inline-flex h-12 w-full items-center justify-center rounded-[10px] font-medium transition-colors',
              tier.featured
                ? 'bg-brand text-white hover:bg-brand-hover'
                : 'border border-ink text-ink hover:bg-paper-tint',
            ]}
          >
            {tier.cta.label}
          </a>
        </div>
      ))}
    </div>
  </Container>
</Section>
