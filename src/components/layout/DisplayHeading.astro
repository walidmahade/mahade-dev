---
interface Props {
  as?: 'h1' | 'h2' | 'h3';
  size?: 'xl' | 'lg' | 'md';
  class?: string;
}

const {
  as: Tag = 'h2',
  size = 'lg',
  class: className = '',
} = Astro.props;

const sizeClass = {
  xl: 'text-display-xl',
  lg: 'text-display-lg',
  md: 'text-display-md',
}[size];
---
<Tag class={`${sizeClass} text-ink ${className}`}>
  <slot />
</Tag>
