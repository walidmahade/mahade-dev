---
import Container from '../layout/Container.astro';
import ServicesMenu from './ServicesMenu.astro';
import { site } from '@/data/site';

// Services is rendered as a <ServicesMenu /> megamenu between Work and Tools.
const trailingNav = [
  { label: 'Tools', href: '/tools' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="sticky top-0 z-40 bg-paper/80 backdrop-blur border-b border-line">
  <Container>
    <div class="flex h-16 items-center justify-between">
      <a
        href="/"
        class="flex items-center gap-2.5 font-semibold tracking-tight text-ink hover:text-brand transition-colors"
        aria-label={`${site.name} — home`}
      >
        <svg aria-hidden="true" width="26" height="26" viewBox="0 0 56 56" fill="none" class="shrink-0">
          <path d="M11 35 L28 15 L45 35" stroke="#0B0D13" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M11 24 L28 44 L45 24" stroke="#4353FF" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>{site.name}</span>
      </a>

      <nav class="flex items-center gap-6 md:gap-8" aria-label="Primary">
        <ul class="hidden md:flex items-center gap-8">
          <li>
            <a
              href="/work"
              class:list={[
                'text-sm transition-colors',
                isActive('/work')
                  ? 'text-ink font-medium'
                  : 'text-ink-muted hover:text-ink',
              ]}
            >
              Work
            </a>
          </li>
          <li><ServicesMenu /></li>
          {trailingNav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'text-sm transition-colors',
                  isActive(item.href)
                    ? 'text-ink font-medium'
                    : 'text-ink-muted hover:text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <a
          href={site.links.cal}
          target="_blank"
          rel="noopener"
          class="inline-flex h-9 items-center rounded-[10px] bg-brand px-4 text-sm font-medium text-white hover:bg-brand-hover transition-colors"
        >
          Book a call
        </a>
      </nav>
    </div>
  </Container>
</header>
