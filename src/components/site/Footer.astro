---
import Container from '../layout/Container.astro';
import { site } from '@/data/site';

const year = new Date().getFullYear();

const links = [
  { label: site.email, href: `mailto:${site.email}`, external: true },
  { label: 'Book a call', href: site.links.cal, external: true },
  { label: 'Upwork', href: site.links.upwork, external: true },
  { label: 'GitHub', href: site.links.github, external: true },
];
---
<footer class="border-t border-line bg-paper-tint py-12 mt-auto">
  <Container>
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="font-semibold text-ink">{site.name}</p>
        <p class="text-body-sm text-ink-muted">
          {site.title} · {site.location}
        </p>
      </div>

      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-body-sm">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener' : undefined}
              class="text-ink-muted hover:text-ink transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <p class="mt-8 text-body-sm text-ink-subtle">
      © {year} {site.name}. All rights reserved.
    </p>
  </Container>
</footer>
