---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
}
const { src, alt, caption, width, height, loading = 'lazy' } = Astro.props;
---
<figure>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
